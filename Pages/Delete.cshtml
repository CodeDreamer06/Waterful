@page
@model Waterful.Pages.DeleteModel
@{
	ViewData["Title"] = "Remove a record";
}

<h3>Are you sure you want to delete this record?</h3>
<div>
	<dl class="row">
		<dt class="col-sm-2">Date</dt>
		<dd class="col-sm-10">@Model.Water.Date</dd>

		<dt class="col-sm-2">Quantity</dt>
		<dd class="col-sm-10">@Model.Water.Quantity</dd>
	</dl>

	<form method="post">
		<input type="hidden" asp-for="Water.Id" />
		<input type="submit" value="Delete" class="btn btn-danger" /> <br/>
		<a asp-page="./Index">Back to list</a>
	</form>
</div>