@page
@model Waterful.Pages.UpdateModel
@{
	ViewData["Title"] = "Update a record";
}

<h3>Update record</h3>
<hr />
<div class="row">
	<div class="col-md-4">
		<form method="post">
			<input type="hidden" asp-for="Water.Id" />
				<div class="form-group mb-3">
					<label asp-for="Water.Date" class="control-label">Date</label>
					<input type="date" asp-for="Water.Date" class="form-control" />
					<span asp-validation-for="Water.Date" class="text-danger" />
				</div>
				<div class="form-group mb-3">
					<label asp-for="Water.Quantity" class="control-label">Quantity</label>
					<input type="number" asp-for="Water.Quantity" class="form-control" />
					<span asp-validation-for="Water.Quantity" class="text-danger" />
				</div>
			<div class="form-group">
				<input type="submit" value="Update" class="btn btn-primary" />
			</div>
		</form>
	</div>
</div> 

<div><a asp-page="Index">Back to List</a></div>